{
  "name": "haru-ai-teacher-backend",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "migrate": "tsx src/scripts/migrate.ts run",
    "migrate:list": "tsx src/scripts/migrate.ts list",
    "predict:nightly": "tsx src/scripts/nightlyPredictionJob.ts",
    "validate-env": "tsx scripts/validate-env.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:security": "vitest run src/middleware/__tests__/auth.test.ts src/middleware/__tests__/security.integration.test.ts src/__tests__/security.e2e.test.ts src/__tests__/security.audit.test.ts src/services/__tests__/DataPrivacyService.security.test.ts",
    "test:security:coverage": "vitest run --coverage src/middleware/__tests__/auth.test.ts src/middleware/__tests__/security.integration.test.ts src/__tests__/security.e2e.test.ts src/__tests__/security.audit.test.ts src/services/__tests__/DataPrivacyService.security.test.ts",
    "security:audit": "npm audit --audit-level=moderate",
    "security:full": "bash scripts/run-security-tests.sh"
  },
  "dependencies": {
    "@aws-sdk/client-bedrock-runtime": "^3.470.0",
    "@aws-sdk/client-polly": "^3.470.0",
    "@aws-sdk/client-s3": "^3.470.0",
    "@aws-sdk/client-transcribe": "^3.470.0",
    "@supabase/supabase-js": "^2.100.1",
    "@types/ioredis": "^4.28.10",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/socket.io": "^3.0.1",
    "@types/uuid": "^10.0.0",
    "argon2": "^0.44.0",
    "axios": "^1.6.2",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.3",
    "multer": "^1.4.5-lts.1",
    "neo4j-driver": "^6.0.1",
    "node-cron": "^4.2.1",
    "socket.io": "^4.8.3",
    "twilio": "^5.13.1",
    "uuid": "^13.0.0",
    "weaviate-ts-client": "^2.2.0"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.10.5",
    "@types/node-cron": "^3.0.11",
    "@types/supertest": "^7.2.0",
    "@vitest/coverage-v8": "^4.1.2",
    "@vitest/ui": "^4.1.2",
    "fast-check": "^4.6.0",
    "socket.io-client": "^4.8.3",
    "supertest": "^7.2.2",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vitest": "^4.1.2"
  }
}
