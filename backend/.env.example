# ============================================================================
# HARU AI TEACHER - BACKEND ENVIRONMENT
# ============================================================================
# Only GROQ_API_KEY and JWT_SECRET are required for a working demo.
# Everything else falls back gracefully (in-memory user store, no Redis,
# Pollinations for free image generation).
# ============================================================================

# ----------------------------------------------------------------------------
# REQUIRED
# ----------------------------------------------------------------------------

# Groq API key — primary AI provider (Llama 3.3 70B)
# Get one free at https://console.groq.com/keys
GROQ_API_KEY=gsk_your_groq_key_here

# JWT signing secret — minimum 32 characters
JWT_SECRET=change-me-to-a-random-32-char-string

# ----------------------------------------------------------------------------
# PROVIDER SELECTION
# ----------------------------------------------------------------------------

# AI provider: groq (default), openai, gemini
AI_PROVIDER=groq
GROQ_MODEL=llama-3.3-70b-versatile

# Image provider: pollinations (free, no key), freepik, openrouter
IMAGE_PROVIDER=pollinations

# ----------------------------------------------------------------------------
# OPTIONAL — alternate AI providers
# ----------------------------------------------------------------------------

# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash

# ----------------------------------------------------------------------------
# OPTIONAL — Supabase for persistent users + credit ledger
# Without these the backend uses an in-memory user store (fine for demo).
# Run backend/src/scripts/migrate-supabase.sql to create the schema.
# ----------------------------------------------------------------------------

# SUPABASE_URL=
# SUPABASE_SERVICE_KEY=

# ----------------------------------------------------------------------------
# OPTIONAL — Redis for distributed rate limiting
# Without it, rate limiting is in-memory per process.
# ----------------------------------------------------------------------------

# REDIS_URL=

# ----------------------------------------------------------------------------
# OPTIONAL — AWS Polly fallback for TTS
# The frontend uses Web Speech API by default; backend Polly is a fallback.
# ----------------------------------------------------------------------------

# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# S3_BUCKET_NAME=haru-ai-teacher-audio

# ----------------------------------------------------------------------------
# SERVER
# ----------------------------------------------------------------------------

PORT=3001
NODE_ENV=development

# Comma-separated origins allowed by CORS
FRONTEND_URL=http://localhost:3000
