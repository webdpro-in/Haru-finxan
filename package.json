{
  "name": "haru-ai-teacher",
  "version": "1.0.0",
  "description": "Haru AI Teacher - anime-style 3D AI tutor for the AMD Slingshot AI in Education hackathon",
  "private": true,
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "install:all": "npm install --prefix frontend && npm install --prefix backend",
    "dev:frontend": "npm run dev --prefix frontend",
    "dev:backend": "npm run dev --prefix backend",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "build:frontend": "npm run build --prefix frontend",
    "build:backend": "npm run build --prefix backend",
    "build": "npm run build:backend && npm run build:frontend",
    "test:frontend": "npm test --prefix frontend",
    "test:backend": "npm test --prefix backend"
  },
  "keywords": [
    "education",
    "ai",
    "live2d",
    "haru",
    "tutor"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
