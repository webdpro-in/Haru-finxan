# FinxanAI Platform - Vercel Environment Variables Template
# Copy these to Vercel Dashboard → Settings → Environment Variables

# ============================================
# REQUIRED - Application will not work without these
# ============================================

# Node Environment
NODE_ENV=production

# Google Gemini API (Required for AI responses)
GEMINI_API_KEY=your_gemini_api_key_here

# JWT Secret (Required for authentication)
# Generate with: openssl rand -hex 32
JWT_SECRET=your_secure_random_string_min_32_chars

# ============================================
# RECOMMENDED - Core features require these
# ============================================

# Supabase (PostgreSQL database)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Neo4j AuraDB (Knowledge graph)
NEO4J_URI=neo4j+s://your-instance.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your_neo4j_password

# Weaviate Cloud (Vector search)
WEAVIATE_URL=https://your-cluster.weaviate.network
WEAVIATE_API_KEY=your_weaviate_api_key

# Upstash Redis (Session cache)
REDIS_URL=redis://default:your_password@your-instance.upstash.io:6379

# ============================================
# OPTIONAL - Additional features
# ============================================

# Frontend URL (for CORS)
FRONTEND_URL=https://your-app.vercel.app

# Encryption Key (for DPDP compliance - data privacy)
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=your_32_byte_hex_string

# Twilio (for WhatsApp parent reports)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# ============================================
# PROVIDER SELECTION
# ============================================

# AI Provider (gemini, openai, groq, aws-bedrock)
AI_PROVIDER=gemini

# Text-to-Speech Provider (browser, aws-polly)
TTS_PROVIDER=browser

# Speech-to-Text Provider (browser, aws-transcribe)
STT_PROVIDER=browser

# Image Provider (pollinations, freepik, openrouter, aws-bedrock, placeholder)
IMAGE_PROVIDER=pollinations

# ============================================
# OPTIONAL PROVIDER API KEYS
# ============================================

# OpenAI (if using OpenAI provider)
OPENAI_API_KEY=your_openai_api_key

# Groq (if using Groq provider)
GROQ_API_KEY=your_groq_api_key

# Freepik (if using Freepik image provider)
FREEPIK_API_KEY=your_freepik_api_key

# AWS (if using AWS providers)
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=ap-south-1

# ============================================
# DEPLOYMENT CONFIGURATION
# ============================================

# Server Port (Vercel will override this)
PORT=3001

# ============================================
# HOW TO USE THIS FILE
# ============================================
#
# 1. Copy each variable name and value
# 2. Go to Vercel Dashboard → Your Project → Settings → Environment Variables
# 3. Click "Add New"
# 4. Paste variable name in "Key" field
# 5. Paste your actual value in "Value" field
# 6. Select "Production" environment
# 7. Click "Save"
# 8. Repeat for all required variables
# 9. Redeploy your application
#
# ============================================
# SECURITY NOTES
# ============================================
#
# - NEVER commit actual API keys to Git
# - Use strong, random values for JWT_SECRET and ENCRYPTION_KEY
# - Rotate API keys regularly
# - Use least-privilege access for database credentials
# - Enable 2FA on all service accounts
#
# ============================================
